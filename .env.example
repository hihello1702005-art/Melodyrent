# MelodyRent root environment template for local full-stack development.
# Copy this file to .env and replace placeholder values before running the app locally.

# MySQL
MYSQL_DATABASE=melodyrent
MYSQL_USER=melodyrent
MYSQL_PASSWORD=melodyrent
MYSQL_ROOT_PASSWORD=root

# Backend datasource
DB_URL=jdbc:mysql://localhost:3306/melodyrent?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
DB_USERNAME=melodyrent
DB_PASSWORD=melodyrent
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=dev

# JWT - replace with a long random 256-bit or stronger secret in real environments
JWT_SECRET=change-me-to-a-very-long-256-bit-secret-for-production-use-only
JWT_ACCESS_MINUTES=30
JWT_REFRESH_DAYS=14

# CORS / frontend
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173
VITE_API_URL=http://localhost:8080/api

# Cloudinary
CLOUDINARY_CLOUD_NAME=demo
CLOUDINARY_API_KEY=demo
CLOUDINARY_API_SECRET=demo
